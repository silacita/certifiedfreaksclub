# Folders below are NEVER uploaded to GitHub (too large or auto-generated).
# Your real site code, images, and audio in public/ ARE uploaded.

# dependencies (install locally with npm install)
node_modules/
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js build cache (recreated when you run npm run dev or npm run build)
.next/
/.next/
out/
/out/
.turbo

# production
/build

# misc
.DS_Store
**/.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo

# NOTE: public/audio/ is intentionally tracked (manifesto, experience, mirror room).
